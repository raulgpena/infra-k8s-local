# -----------------------------------------------------------------------------
# Name:       terraform.tfvars.example
# Author:     Raul Pena (raul.pena@gmail.com)
# Created At: 06/11/2026
# -----------------------------------------------------------------------------

kube_context         = "k3d-local-dev"
environment          = "local"
enable_cert_manager  = true
enable_argocd        = true
argocd_chart_version = "7.7.11"
argocd_host          = "argocd.127.0.0.1.nip.io"

# argocd-apps: one ApplicationSet auto-discovers apps from the gitops repo
# (layout: apps/<project>/<app>/), mapping each app to a per-team AppProject.
enable_argocd_apps        = true
argocd_apps_chart_version = "2.0.2"
argocd_apps_values_file   = "" # leave empty to use the generated template

gitops_repo_url      = "https://github.com/your-org/infra-argocd-local"
gitops_repo_revision = "main"

argocd_projects = [
  { name = "snow-white", description = "Snow White" },
  { name = "cars", description = "Cars" },
]

# base-app chart published to GitHub Packages (ghcr). Apps render from this
# chart + their own values.yaml in the gitops repo (Argo CD multi-source).
base_app_chart_repo    = "ghcr.io/raulgpena/charts"
base_app_chart_name    = "base-app"
base_app_chart_version = "0.1.0"

# Argo CD repository credentials. Leave empty for public repos/packages.
# For private ones, fill these in your gitignored terraform.tfvars (never here).
# gitops_repo_username = "your-github-username"
# gitops_repo_password = "ghp_xxxxxxxxxxxxxxxxxxxx"   # repo read scope
# ghcr_username        = "your-github-username"
# ghcr_password        = "ghp_xxxxxxxxxxxxxxxxxxxx"   # read:packages scope
